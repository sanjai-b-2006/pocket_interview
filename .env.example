# Fireworks AI (Gemma 4 access)
FIREWORKS_API_KEY=your_fireworks_api_key_here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
GEMMA_MODEL=accounts/fireworks/models/gemma-4

# Local ASR (faster-whisper). Set ASR_DEVICE=cuda once running on AMD Developer Cloud
# with ROCm-enabled torch/ctranslate2 -- no code changes needed, just this env var.
ASR_DEVICE=cpu
ASR_MODEL_SIZE=base
ASR_COMPUTE_TYPE=int8

DATABASE_URL=sqlite:///./interview_coach.db

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
