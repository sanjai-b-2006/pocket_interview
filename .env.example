# Fireworks AI (Gemma 4 access)
FIREWORKS_API_KEY=your_fireworks_api_key_here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
GEMMA_MODEL=accounts/fireworks/models/gemma-4

# Local ASR (faster-whisper). Set ASR_DEVICE=cuda once running on AMD Developer Cloud
# with ROCm-enabled torch/ctranslate2 -- no code changes needed, just this env var.
ASR_DEVICE=cpu
# Use "tiny" instead of "base" on memory-constrained hosts (e.g. Render free tier's 512MB cap).
ASR_MODEL_SIZE=base
ASR_COMPUTE_TYPE=int8
# Set to false on memory-constrained hosts to skip librosa's numba-JIT pitch analysis pass.
ENABLE_PITCH_ANALYSIS=true

DATABASE_URL=sqlite:///./interview_coach.db

# Comma-separated list of frontend origins allowed to call this API (CORS).
# For local dev, the default below is fine. When deployed, set this to your
# actual deployed frontend URL(s), e.g. https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
